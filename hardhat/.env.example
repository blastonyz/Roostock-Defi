# Rootstock RPCs
RSK_MAINNET_RPC_URL=https://public-node.rsk.co
RSK_TESTNET_RPC_URL=https://public-node.testnet.rsk.co

# Deployer private key (without 0x)
RSK_PRIVATE_KEY=

# ERC-4337 EntryPoint — elige según bundler:
# eth-infinitism v0.7 canonical:                             0x0000000071727De22E5E9d8BAf0edAc6f37da032
# eth-infinitism v0.6 canonical (testnet-rpc.etherspot.io):  0x5FF137D4b0FDCD49DcA30c7CF57E578a026d2789
# Rootstock testnet (rootstocktestnet-bundler.etherspot.io): 0x48e60BBb664aEfAc9f14aDB42e5FB5b4a119EB66
ENTRY_POINT_ADDRESS=0x5FF137D4b0FDCD49DcA30c7CF57E578a026d2789
# Optional: fail fast if EntryPoint address has no code on current network
REQUIRE_ENTRYPOINT=false
# Optional: if bundler reports different entrypoints, use the first supported one automatically
AUTO_SELECT_BUNDLER_ENTRYPOINT=false

# Optional: force gas limit for AccountFactory.createAccount (integer, no decimals)
CREATE_ACCOUNT_GAS_LIMIT=1500000

# Optional AA infra endpoints
BUNDLER_RPC_URL=
PAYMASTER_RPC_URL=
